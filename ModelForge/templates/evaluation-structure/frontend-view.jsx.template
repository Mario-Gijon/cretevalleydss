import { forwardRef, useImperativeHandle } from "react";
import { Alert } from "@mui/material";

const {{ view_component_name }} = (
  {
    evaluationContext,
    evaluationPayload,
    setEvaluationPayload,
    collectivePayload,
    readOnly,
    loading,
  },
  ref
) => {
  void evaluationContext;
  void setEvaluationPayload;
  void collectivePayload;
  void readOnly;
  void loading;

  const preparePayloadRead = async () => evaluationPayload;
  const flushPendingEdits = async () => evaluationPayload;

  useImperativeHandle(ref, () => ({
    flushPendingEdits,
    preparePayloadRead,
  }));

  return (
    <Alert severity="info">
      {{ evaluation_structure_key }} is under development.
    </Alert>
  );
};

export default forwardRef({{ view_component_name }});
