export const {{ validate_function_name }} = ({ parameter, value }) => {
  if (value === null || value === undefined || value === "") {
    if (parameter.required === true) {
      return {
        ok: false,
        message: "is required",
        value,
      };
    }

    return {
      ok: true,
      value: parameter.default,
    };
  }

  // TODO: validate and normalize the structure-owned value.
  return {
    ok: true,
    value,
  };
};
