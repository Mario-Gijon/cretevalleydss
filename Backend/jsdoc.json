{
  "source": {
    "include": [
      "./controllers",
      "./modules",
      "./models",
      "./middlewares",
      "./services",
      "./utils",
      "./database",
      "./app.js",
      "./server.js"
    ],
    "exclude": [
      "./node_modules",
      "./docs-generated"
    ],
    "includePattern": ".+\\.js$"
  },
  "opts": {
    "destination": "./docs-generated/jsdoc",
    "encoding": "utf8",
    "readme": "./docs/jsdoc-home.md",
    "recurse": true
  },
  "templates": {
    "default": {
      "outputSourceFiles": false,
      "useLongnameInNav": true,
      "includeDate": false
    }
  }
}
