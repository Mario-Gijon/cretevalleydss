{
  "name": "back",
  "module": "index.ts",
  "type": "module",
  "devDependencies": {
    "@redocly/cli": "^2.24.1",
    "@types/bun": "latest",
    "jsdoc": "^4.0.5"
  },
  "peerDependencies": {
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@getbrevo/brevo": "^2.5.0",
    "axios": "^1.8.4",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "dayjs": "^1.11.13",
    "days": "^1.1.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-validator": "^7.2.1",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.30.1",
    "mongoose": "^8.9.2",
    "nanoid": "^5.0.9",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.4",
    "nodemon": "^3.1.9",
    "resend": "^4.0.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "scripts": {
    "dev": "NODE_ENV=development nodemon server.js",
    "start": "NODE_ENV=production node server.js",
    "docs:openapi": "node scripts/generate-openapi.mjs",
    "docs:openapi:lint": "redocly lint openapi/openapi.json",
    "docs:openapi:bundle": "redocly bundle openapi/openapi.json -o openapi/bundled-openapi.json",
    "docs:redoc": "bun run docs:openapi && bun run docs:openapi:bundle && redocly build-docs openapi/bundled-openapi.json -o docs/api-reference.html",
    "docs:jsdoc": "node ./node_modules/jsdoc/jsdoc.js ./controllers ./modules ./models ./middlewares ./services ./utils ./database ./app.js ./server.js -r -d ./docs/jsdoc -R ./docs/jsdoc-home.md -c jsdoc.json",
    "docs:build": "bun run docs:jsdoc && bun run docs:redoc"
  }
}